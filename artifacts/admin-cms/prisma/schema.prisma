generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  sections    Json     // Array of { type: string, data: any, id: string }
  seo         Json?    // { title: string, description: string, ogImage?: string }
  status      String   @default("draft") // draft, published
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GlobalConfig {
  id        String   @id @default("global")
  navbar    Json?    // { logo: string, links: Array<{label, href}> }
  footer    Json?    // { stats: Array<{label, value}>, social: Array<{type, url}> }
  theme     Json?    // { primaryColor: string, font: string, borderRadius: string }
  updatedAt DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  url       String
  name      String
  type      String
  size      Int
  createdAt DateTime @default(now())
}
